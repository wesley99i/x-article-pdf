    parts.append('<div class="author-info">')
    verified = author.get("verification", {}).get("verified", False)
    badge = '<span class="verified-badge">✓</span>' if verified else ""
    parts.append(f'<div class="author-name">{author.get("name","")} {badge}</div>')
    parts.append(f'<div class="author-handle">@{author.get("screen_name","")}</div>')
    bio = author.get("description", "")
    if bio:
        parts.append(f'<div class="author-bio">{bio}</div>')
    parts.append("</div></div></div>")

