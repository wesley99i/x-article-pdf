    # Pre-download all body images from media_map
    media_map = data.get("media_map", {})
    media_uris = {}
    for mid, img_url in media_map.items():
        uri = dl_image(img_url)
        if uri and uri.startswith("data:"):
            media_uris[mid] = uri

    # Pre-download embedded tweet avatars and media
    embedded_tweets = data.get("embedded_tweets", {})
    tweet_avatars = {}
