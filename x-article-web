<body>
<div class="card">
  <div class="logo">📄</div>
  <h1>X Article → PDF</h1>
  <p class="sub">Paste one or more X article links to download styled PDFs for offline reading.</p>
  <form id="form" method="POST" action="/convert-batch">
    <label for="urls">Article URLs</label>
    <div class="input-row">
      <textarea id="urls" name="urls"
                placeholder="Paste X article URLs here, one per line"
                rows="6" required autofocus></textarea>
      <button type="button" class="paste-btn" id="pasteBtn">📋 Paste</button>
    </div>
    <button type="submit" id="btn">Convert All to PDF</button>
  </form>
  <div id="status" class="status"></div>
  <div id="spinner" class="spinner"></div>
  <div id="results" class="results"></div>
  <div class="example">
    Example: <code>https://x.com/IBuzovskyi/status/2066145326780518736</code><br>
    Paste multiple URLs — one per line — and click <strong>Convert All</strong>
  </div>
</div>
<div class="footer">
  Open source &middot; Powered by Chrome headless &middot; PDFs saved to server
</div>
<script>
const form = document.getElementById('form');
const btn = document.getElementById('btn');
const status = document.getElementById('status');
const spinner = document.getElementById('spinner');
const resultsDiv = document.getElementById('results');
const pasteBtn = document.getElementById('pasteBtn');
const urlsInput = document.getElementById('urls');

// Paste button — reads clipboard and fills textarea
pasteBtn.addEventListener('click', async () => {
  try {
    const text = await navigator.clipboard.readText();
    urlsInput.value = text;
    status.className = 'status ok';
    status.textContent = 'Pasted ' + text.split('\n').filter(l => l.trim()).length + ' URL(s)';
  } catch (err) {
    status.className = 'status error';
    status.textContent = 'Could not read clipboard — paste manually or check browser permissions';
  }
});

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const urls = urlsInput.value.trim();
  if (!urls) return;

  btn.disabled = true;
  spinner.style.display = 'block';
  status.className = 'status';
  status.textContent = 'Converting articles…';
  resultsDiv.style.display = 'none';

  try {
    const resp = await fetch('/convert-batch', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: 'urls=' + encodeURIComponent(urls),
    });

    const result = await resp.json();
    spinner.style.display = 'none';

    if (!resp.ok) {
      status.className = 'status error';
      status.textContent = result.error || 'Something went wrong';
      btn.disabled = false;
      return;
    }

    // Render results list
    resultsDiv.style.display = 'block';
    let html = '<h3>Results</h3><div class="result-list">';
    let okCount = 0, failCount = 0;
    for (const item of result.results) {
      if (item.success) {
        okCount++;
        html += '<div class="result-item ok">✅ <a href="' + item.download_url + '" target="_blank">'
             + item.title + '</a> <span class="size">(' + item.size_kb + ' KB)</span></div>';
      } else {
        failCount++;
        html += '<div class="result-item error">❌ ' + item.url + ' — ' + item.error + '</div>';
      }
    }
    html += '</div>';
    html += '<div class="result-summary">' + okCount + ' converted, ' + failCount + ' failed</div>';
    resultsDiv.innerHTML = html;

    status.className = 'status ok';
    const p = okCount === 1 ? '' : 's';
    status.textContent = 'Done — ' + okCount + ' PDF' + p + ' saved to ~/Downloads/x-articles/';
  } catch (err) {
    status.className = 'status error';
    status.textContent = 'Network error — is the server running?';
    spinner.style.display = 'none';
  } finally {
    btn.disabled = false;
  }
});
</script>
</body>
</html>
"""


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        sys.stderr.write(f"[x-article-web] {args[0]} {args[1]} {args[2]}\n")

    def _send_json(self, code, body):
        body_bytes = json.dumps(body).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body_bytes)))
        self.end_headers()
        self.wfile.write(body_bytes)

    def _send_html(self, code, html):
        body = html.encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path == "/" or self.path == "/index.html":
            self._send_html(200, PAGE_HTML)
        elif self.path.startswith("/download/"):
            filename = urllib.parse.unquote(self.path[len("/download/"):])
            # Prevent path traversal
            if ".." in filename or "/" in filename:
                self.send_response(403)
                self.end_headers()
                return
            filepath = DOWNLOAD_DIR / filename
            if not filepath.exists():
                self.send_response(404)
                self.end_headers()
                return
            with open(filepath, "rb") as f:
                data = f.read()
            self.send_response(200)
            self.send_header("Content-Type", "application/pdf")
            self.send_header("Content-Disposition", f'inline; filename="{filename}"')
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
        else:
            self.send_response(404)
            self.end_headers()

    def do_POST(self):
        if self.path == "/convert":
            self._handle_single_convert()
        elif self.path == "/convert-batch":
            self._handle_convert_batch()
        else:
            self._send_json(404, {"error": "Not found"})

    def _handle_single_convert(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode("utf-8")
        params = urllib.parse.parse_qs(body)
        url = (params.get("url") or [""])[0].strip()

        if not url:
            self._send_json(400, {"error": "URL is required"})
            return

        tweet_id = extract_tweet_id(url)
        if not tweet_id:
            self._send_json(400, {"error": "Invalid X/Twitter URL. Use format: https://x.com/user/status/1234567890"})
            return

        try:
            data = fetch_article(tweet_id)
            html = render_html(data)
            pdf_bytes, pdf_path = generate_pdf(html, tweet_id, data['title'])

            # Nice filename for the download
            safe_title = re.sub(r'[^\w\s-]', '', data['title'])[:60].strip().replace(' ', '_')
            filename = f"{safe_title}.pdf" if safe_title else f"{tweet_id}-article.pdf"

            self.send_response(200)
            self.send_header("Content-Type", "application/pdf")
            self.send_header("Content-Disposition", f'attachment; filename="{filename}"')
            self.send_header("X-Filename", filename)
            self.send_header("Content-Length", str(len(pdf_bytes)))
            self.end_headers()
            self.wfile.write(pdf_bytes)

            size_kb = len(pdf_bytes) / 1024
            print(f"  ✓ {data['title'][:60]}… → {pdf_path} ({size_kb:.0f} KB)", flush=True)

        except ValueError as e:
            self._send_json(400, {"error": str(e)})
        except urllib.error.URLError:
            self._send_json(502, {"error": "Failed to fetch article — network issue or invalid URL"})
        except subprocess.TimeoutExpired:
            self._send_json(500, {"error": "PDF generation timed out (article may be very long)"})
        except Exception as e:
            self._send_json(500, {"error": f"Internal error: {e}"})

    def _handle_convert_batch(self):
        """Convert multiple URLs, save to disk, return JSON with download links."""
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode("utf-8")
        params = urllib.parse.parse_qs(body)
        urls_text = (params.get("urls") or [""])[0].strip()

        if not urls_text:
            self._send_json(400, {"error": "At least one URL is required"})
            return

        # Parse URLs — one per line
        urls = [u.strip() for u in urls_text.split("\n") if u.strip()]

        results = []
        for url in urls:
            try:
                tweet_id = extract_tweet_id(url)
                if not tweet_id:
                    results.append({"url": url, "success": False, "error": "Invalid X/Twitter URL"})
                    continue

                data = fetch_article(tweet_id)
                html = render_html(data)
                pdf_bytes, pdf_path = generate_pdf(html, tweet_id, data["title"])

                safe_title = re.sub(r'[^\w\s-]', "", data["title"])[:60].strip().replace(" ", "_")
                filename = f"{safe_title}.pdf" if safe_title else f"{tweet_id}-article.pdf"

                size_kb = round(len(pdf_bytes) / 1024)
                print(f"  ✓ {data['title'][:60]}… → {pdf_path} ({size_kb} KB)", flush=True)

                results.append({
                    "url": url,
                    "success": True,
                    "title": data["title"][:80],
                    "filename": filename,
                    "download_url": f"/download/{urllib.parse.quote(filename)}",
                    "size_kb": size_kb,
                })
            except ValueError as e:
                results.append({"url": url, "success": False, "error": str(e)})
            except urllib.error.URLError:
                results.append({"url": url, "success": False, "error": "Network error fetching article"})
            except subprocess.TimeoutExpired:
                results.append({"url": url, "success": False, "error": "PDF generation timed out"})
            except Exception as e:
                results.append({"url": url, "success": False, "error": str(e)[:100]})

        self._send_json(200, {"results": results})


def get_local_ip() -> str:
    """Get the primary non-loopback IPv4 address."""
    try:
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.settimeout(0.1)
        s.connect(("10.255.255.255", 1))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except Exception:
        pass
    try:
        out = subprocess.run(["hostname", "-I"], capture_output=True, text=True, timeout=3)
        ips = out.stdout.strip().split()
        if ips:
            return ips[0]
    except Exception:
        pass
    return "127.0.0.1"


def main():
    port = PORT
    for i, arg in enumerate(sys.argv[1:]):
        if arg == "--port" and i + 2 < len(sys.argv):
            port = int(sys.argv[i + 2])
        elif arg.startswith("--port="):
            port = int(arg.split("=", 1)[1])

    local_ip = get_local_ip()

    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("0.0.0.0", port), Handler) as httpd:
        print(f"""
┌────────────────────────────────────────────┐
│  📄 X Article → PDF Web App                │
│                                            │
│  Local:   http://127.0.0.1:{port}          │""")
        if local_ip != "127.0.0.1":
            print(f"""│  Network: http://{local_ip}:{port}              │""")
        print(f"""│                                            │
│  Open on your phone/tablet to download     │
│  PDFs directly from X article links!       │
│                                            │
│  PDFs saved to:                            │
│    ~/Downloads/x-articles/                 │
│                                            │
│  Ctrl+C to stop                            │
└────────────────────────────────────────────┘""", flush=True)
        httpd.serve_forever()


if __name__ == "__main__":
    main()