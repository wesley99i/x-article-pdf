def extract_tweet_id(url: str) -> Optional[str]:
    m = re.search(r'(?:x\.com|twitter\.com)/\w+/status/(\d+)', url)
    return m.group(1) if m else None


def fetch_article(tweet_id: str) -> dict:
    api_url = f"https://api.fxtwitter.com/status/{tweet_id}"
    req = urllib.request.Request(api_url, headers={"User-Agent": "x-article-pdf/1.0"})
    with urllib.request.urlopen(req, timeout=15) as resp:
        data = json.loads(resp.read().decode())
    if data.get("code") != 200:
        raise ValueError(f"API error: {data.get('message', 'unknown')}")
    tweet = data.get("tweet", {})
    article = tweet.get("article")
    if not article:
        raise ValueError("Tweet is not an X Article (long-form post)")

    # Build media_id → CDN URL map from article.media_entities
    media_map = {}
    for m in article.get("media_entities", []):
        mid = m.get("media_id", "")
        iurl = m.get("media_info", {}).get("original_img_url", "")
        if mid and iurl:
            media_map[mid] = iurl

    return {
        "title": article.get("title", ""),
        "author": tweet.get("author", {}),
        "created_at": tweet.get("created_at", ""),
        "metrics": {
            "likes": tweet.get("likes", 0),
            "replies": tweet.get("replies", 0),
            "retweets": tweet.get("retweets", 0),
            "bookmarks": tweet.get("bookmarks", 0),
            "views": tweet.get("views", 0),
        },
        "blocks": article.get("content", {}).get("blocks", []),
        "entity_map": article.get("content", {}).get("entityMap", []),
        "cover_url": (
            article.get("cover_media", {})
            .get("media_info", {})
            .get("original_img_url")
        ),
        "media_map": media_map,
        "url": f"https://x.com/{tweet.get('author', {}).get('screen_name', '')}/status/{tweet_id}",
        "embedded_tweets": _fetch_embedded_tweets(article),

    }


def _fetch_embedded_tweets(article: dict) -> dict:
    """Pre-fetch all embedded tweets referenced in the article's entity map."""
    entity_map = article.get("content", {}).get("entityMap", [])
    tweet_ids = set()
    for ent in entity_map:
        val = ent.get("value", {})
        if val.get("type") == "TWEET":
            tid = val.get("data", {}).get("tweetId", "")
            if tid:
                tweet_ids.add(tid)
    results = {}
    for tid in sorted(tweet_ids):
        data = fetch_embedded_tweet(tid)
        if data:
            results[tid] = data
    return results


def fetch_embedded_tweet(tweet_id: str) -> dict:
    """Fetch an embedded tweet's content via fxtwitter API."""
    try:
        url = f"https://api.fxtwitter.com/status/{tweet_id}"
        req = urllib.request.Request(url, headers={"User-Agent": "x-article-pdf/1.0"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read().decode())
        if data.get("code") != 200:
            return {}
        t = data.get("tweet", {})

        def find_twimg(obj, depth=0):
            if depth > 3:
                return []
            urls = []
            if isinstance(obj, dict):
                for k, v in obj.items():
                    if isinstance(v, str) and "pbs.twimg.com/media" in v:
                        urls.append(v)
                    elif isinstance(v, (dict, list)):
                        urls.extend(find_twimg(v, depth + 1))
            elif isinstance(obj, list):
                for item in obj:
                    urls.extend(find_twimg(item, depth + 1))
            return urls

        img_urls = list(set(find_twimg(data)))
        return {
            "id": tweet_id,
            "author": t.get("author", {}),
            "text": t.get("text") or t.get("raw_text", {}).get("text", ""),
            "created_at": t.get("created_at", ""),
            "likes": t.get("likes", 0),
            "retweets": t.get("retweets", 0),
            "views": t.get("views", 0),
            "media_urls": img_urls,
            "url": f"https://x.com/{t.get('author', {}).get('screen_name', '')}/status/{tweet_id}",
        }
    except Exception:
        return {}


def dl_image(url: str, timeout: int = 10) -> str:
    """Download an image and return it as a base64 data URI."""
    if not url:
        return ""
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "x-article-pdf/1.0"})
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            raw = resp.read()
        ct = resp.headers.get("Content-Type", "")
        if "png" in ct:
            mime = "image/png"
        elif "gif" in ct:
            mime = "image/gif"
        elif "webp" in ct:
            mime = "image/webp"
        elif url.endswith(".png"):
            mime = "image/png"
        elif url.endswith(".gif"):
            mime = "image/gif"
        elif url.endswith(".webp"):
            mime = "image/webp"
        else:
            mime = "image/jpeg"
        b64 = base64.b64encode(raw).decode("ascii")
        return f"data:{mime};base64,{b64}"
    except Exception:
        return url  # fallback: let Chrome try to fetch it


def apply_inline_styles(text: str, ranges: list) -> str:
    styled = text
    for r in sorted(ranges, key=lambda x: -x.get("offset", 0)):
        off = r.get("offset", 0)
        length = r.get("length", 0)
        style = r.get("style", "")
        before = styled[:off]
        mid = styled[off:off + length]
        after = styled[off + length:]
        if style == "Bold":
            mid = f"<strong>{mid}</strong>"
        elif style == "Italic":
            mid = f"<em>{mid}</em>"
        styled = before + mid + after
    return styled


