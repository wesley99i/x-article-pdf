            uri = dl_image(av)
            if uri and uri.startswith("data:"):
                tweet_avatars[tid] = uri
        tw_media = []
        for mu in tw.get("media_urls", []):
            uri = dl_image(mu)
            if uri and uri.startswith("data:"):
                tw_media.append(uri)
        tweet_media[tid] = tw_media

