    if cover_data_uri:
        parts.append(f'<img class="cover-image" src="{cover_data_uri}" alt=""/>')

    # Title + meta
    parts.append(f"<h1>{data['title']}</h1>")
    parts.append(f"<div class='article-meta'>{data['created_at']}</div>")

    # Body
    parts.append('<div class="article-body">')
    for block in blocks:
        typ = block.get("type", "unstyled")
        text = block.get("text", "")
        sty_ranges = block.get("inlineStyleRanges", [])
        ent_ranges = block.get("entityRanges", [])

        if typ == "atomic":
            if not ent_ranges:
                parts.append('<div class="divider">· · ·</div>')
                continue
            for er in ent_ranges:
                key = str(er.get("key", 0))
                ent = entities.get(key, {})
                etype = ent.get("type", "")
                edata = ent.get("data", {})
                if etype == "DIVIDER":
                    parts.append('<div class="divider">· · ·</div>')
                elif etype == "LINK":
                    parts.append(f'<p><a href="{edata.get("url","")}">{edata.get("url","")}</a></p>')
                elif etype == "MARKDOWN":
                    parts.append(f'<div class="code-block">{edata.get("markdown","")}</div>')
                elif etype == "TWEET":
                    tid = edata.get("tweetId", "")
                    tw = embedded_tweets.get(tid, {})
                    if tw:
                        ta = tw.get("author", {})
                        tav = tweet_avatars.get(tid, "")
                        tw_media = tweet_media.get(tid, [])
                        tw_text = tw.get("text", "").strip()
                        tw_likes = tw.get("likes", 0)
                        tw_rts = tw.get("retweets", 0)
                        tw_views = tw.get("views", 0)
                        tw_url = tw.get("url", f"https://x.com/i/status/{tid}")
                        card_parts = ['<div class="tweet-card">']
                        card_parts.append('<div class="tweet-author">')
                        if tav:
                            card_parts.append(f'<div class="tweet-avatar"><img src="{tav}" alt=""/></div>')
                        else:
                            card_parts.append('<div class="tweet-avatar"></div>')
                        tname = ta.get("name", "")
                        vbadge = '<span class="tweet-vbadge">✓</span>' if ta.get("verification", {}).get("verified") else ""
                        card_parts.append(
                            f'<div class="tweet-author-info">'
                            f'<div class="tweet-author-name">{tname} {vbadge}</div>'
                            f'<div class="tweet-author-handle">@{ta.get("screen_name","")}</div>'
                            f'</div></div>'
                        )
                        if tw_text:
                            card_parts.append(f'<div class="tweet-text">{tw_text}</div>')
                        for mu in tw_media:
                            card_parts.append(f'<img class="tweet-media-img" src="{mu}" alt=""/>')
                        card_parts.append(
                            f'<div class="tweet-metrics">'
                            f'<div><span>{tw_likes}</span> Likes</div>'
                            f'<div><span>{tw_rts}</span> Reposts</div>'
                            f'<div><span>{tw_views:,}</span> Views</div>'
                            f'</div>'
                        )
                        card_parts.append(f'<a class="tweet-link" href="{tw_url}">🔗 See original tweet</a>')
                        card_parts.append('</div>')
                        parts.append("".join(card_parts))
                    else:
                        parts.append(f'<blockquote>↗ <a href="https://x.com/i/status/{tid}">Embedded tweet</a></blockquote>')
                elif etype == "MEDIA":
                    media_items = edata.get("mediaItems", [])
                    for item in media_items:
                        mid = item.get("mediaId", "")
                        uri = media_uris.get(mid, "")
                        caption = edata.get("caption", "")
                        if uri:
                            parts.append(f'<img class="body-image" src="{uri}" alt=""/>')
                            if caption:
                                parts.append(f'<div class="body-image-cap">{caption}</div>')
                else:
                    parts.append('<div class="divider">· · ·</div>')
            continue

        if typ == "header-two":
            parts.append(f"<h2>{text}</h2>")
            continue

        if typ in ("ordered-list-item", "unordered-list-item"):
            styled = apply_inline_styles(text, sty_ranges)
            parts.append(f"<li>{styled}</li>")
            continue

        if typ == "blockquote" and text.strip():
            styled = apply_inline_styles(text, sty_ranges)
            parts.append(f"<blockquote>{styled}</blockquote>")
            continue

        if text.strip():
            styled = apply_inline_styles(text, sty_ranges)
            parts.append(f"<p>{styled}</p>")
        # Also render any MEDIA entities attached to this block
        for er in ent_ranges:
            key = str(er.get("key", 0))
            ent = entities.get(key, {})
            etype = ent.get("type", "")
            if etype == "MEDIA":
                edata = ent.get("data", {})
                media_items = edata.get("mediaItems", [])
                for item in media_items:
                    mid = item.get("mediaId", "")
                    uri = media_uris.get(mid, "")
                    caption = edata.get("caption", "")
                    if uri:
                        parts.append(f'<img class="body-image" src="{uri}" alt=""/>')
                        if caption:
                            parts.append(f'<div class="body-image-cap">{caption}</div>')
            elif etype == "TWEMOJI":
                pass  # inline emoji handled via unicode text already

    parts.append("</div>")

    # Metrics
    m = data["metrics"]
    parts.append(
        '<div class="metrics-bar">'
        f'<div><span class="val">{m["views"]:,}</span> Views</div>'
        f'<div><span class="val">{m["replies"]}</span> Replies</div>'
        f'<div><span class="val">{m["retweets"]}</span> Reposts</div>'
        f'<div><span class="val">{m["likes"]}</span> Likes</div>'
        f'<div><span class="val">{m["bookmarks"]}</span> Bookmarks</div>'
        "</div>"
    )

    parts.append(f'<div class="footer">Saved from <a href="{data["url"]}">X Article</a></div>')
    parts.append("</body></html>")
    return "\n".join(parts)


def generate_pdf(html: str, tweet_id: str, title: str) -> tuple[bytes, str]:
    """Render HTML to PDF via Chrome headless.
    Returns (pdf_bytes, disk_path) — the PDF is saved persistently on disk.
    """
    safe_title = re.sub(r'[^\w\s-]', '', title)[:60].strip().replace(' ', '_') or tweet_id
    pdf_path = str(DOWNLOAD_DIR / f"{safe_title}.pdf")

    with tempfile.NamedTemporaryFile(suffix=".html", prefix="x-article-", delete=False, mode="w") as f:
        f.write(html)
        tmp_html = f.name

    try:
        subprocess.run(
            [CHROME, "--headless", "--disable-gpu", "--no-margins",
             "--disable-software-rasterizer",
             f"--print-to-pdf={pdf_path}",
             "--print-to-pdf-no-header",
             f"file://{tmp_html}"],
            check=True, capture_output=True, timeout=30,
        )
        # If the PDF already existed (re-convert), overwrite is fine
        with open(pdf_path, "rb") as f:
            pdf_bytes = f.read()
        return pdf_bytes, pdf_path
    finally:
        os.unlink(tmp_html)


